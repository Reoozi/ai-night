# PostgreSQL Vector Database Configuration
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DB=rag_db
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=password
# Connection string format: postgresql://user:password@host:port/database

# Embedding Model Configuration
# Options:
#   all-MiniLM-L6-v2 (default) - Fast, 384 dimensions
#   paraphrase-MiniLM-L6-v2 - Good for paraphrasing
#   all-mpnet-base-v2 - Better quality, 768 dimensions (slower)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Document Splitting Configuration
# CHUNK_SIZE: Number of tokens per chunk (recommended: 500-1000)
# CHUNK_OVERLAP: Number of overlapping tokens between chunks (recommended: 50-100)
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval Configuration
# TOP_K_RESULTS: Default number of results to retrieve (recommended: 3-10)
TOP_K_RESULTS=3

# NVIDIA API Configuration
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: Ollama Configuration (if using local Ollama)
Embedding_OLLAMA=nomic-embed-text:latest

# Optional: Application Settings
DEBUG=false
LOG_LEVEL=INFO
